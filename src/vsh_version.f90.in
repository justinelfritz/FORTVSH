MODULE VSH_VERSION
  USE KINDS, ONLY: i4
  IMPLICIT NONE
  PRIVATE
  PUBLIC :: VERSION_MAJOR, VERSION_MINOR, VERSION_PATCH, VERSION_STRING
  INTEGER(KIND=i4), PARAMETER :: VERSION_MAJOR  = @PROJECT_VERSION_MAJOR@
  INTEGER(KIND=i4), PARAMETER :: VERSION_MINOR  = @PROJECT_VERSION_MINOR@
  INTEGER(KIND=i4), PARAMETER :: VERSION_PATCH  = @PROJECT_VERSION_PATCH@
  CHARACTER(LEN=*), PARAMETER :: VERSION_STRING = "@PROJECT_VERSION@"
END MODULE VSH_VERSION
